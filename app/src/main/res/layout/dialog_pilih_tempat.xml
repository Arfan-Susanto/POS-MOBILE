<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_dinein"
    android:padding="20dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:text="Pilih Tempat"
            android:textColor="@color/primary"
            android:fontFamily="@font/plus_jakarta"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:background="@drawable/bg_close_circle_kasir"
            android:padding="10dp"
            app:tint="@color/accent"
            android:src="@drawable/ic_close" />

    </RelativeLayout>

    <GridLayout
        android:id="@+id/gridMeja"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:alignmentMode="alignMargins"
        android:columnCount="2"
        android:rowCount="4"
        android:useDefaultMargins="true"
        android:gravity="center" />

    <LinearLayout
        android:id="@+id/btnSelesai"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_button_selesai"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/ibm_plex"
            android:text="Selesai"
            android:textAllCaps="false"
            android:textColor="@color/accent"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>