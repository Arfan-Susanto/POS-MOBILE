<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="CategorySelected">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">43dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bg_category_selected</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="CategoryUnselected">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">43dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bg_category_unselected</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="CategoryDialogUnselected">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingStart">22dp</item>
        <item name="android:paddingEnd">22dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:background">@drawable/bg_category_dialog_unselected</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="RoundedImageMenu">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="CustomPopupMenuAdmin" parent="Widget.AppCompat.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_menu_admin</item>
    </style>

    <style name="CustomPopupMenu" parent="Widget.AppCompat.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_menu</item>
    </style>


    <style name="CategoryPilihMenu">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingStart">22dp</item>
        <item name="android:paddingEnd">22dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:background">@drawable/bg_category_unselected_kasir</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="OrderButtonSelected">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bg_order_selected</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="OrderButtonUnselected">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bg_order_unselected</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CategoryTagAdmin">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:background">@drawable/bg_kategori_menu</item>
    </style>

    <style name="CategoryTagKasir">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">@font/plus_jakarta</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:background">@drawable/bg_kategori_primary</item>

    </style>

    <style name="BottomRoundedCard">
        <item name="cornerFamily">rounded</item>

        <item name="cornerSizeTopLeft">28dp</item>
        <item name="cornerSizeTopRight">28dp</item>

        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="RoundedImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

</resources>